{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "widecomplextachycardia",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "widecomplextachycardia.com", "custom_domain": true },
    { "pattern": "www.widecomplextachycardia.com", "custom_domain": true }
  ]
}
